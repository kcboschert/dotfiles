#!/usr/bin/env bash

set -o nounset -o pipefail -o errexit

audio_format=""
mapfile -t formats < <(yt-dlp --quiet --list-formats "$@" | tail -n +3 | sort -r -n)
format_line=$(gum choose --header "Video Format" --height=15 "${formats[@]}")

format=$(echo "${format_line}" | awk '{ print $1 }')

if echo "${format_line}" | grep -q "video only"; then
  mapfile -t audio_formats < <(printf '%s\n' "${formats[@]}" | grep "audio only")
  audio_format=$(gum choose --header "Audio Format" --height=15 "${audio_formats[@]}" | awk '{ print $1 }')
  format="${format}+${audio_format}"
fi

exec yt-dlp \
  --format "${format}" \
  --output '%(title)s.%(ext)s' \
  --merge-output-format mp4 \
  --embed-thumbnail \
  --embed-metadata \
  --write-subs \
  --sub-lang en \
  "$@"
