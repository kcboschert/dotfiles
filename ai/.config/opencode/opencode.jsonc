{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "default_agent": "plan",
  "enabled_providers": ["ollama", "llamacpp"],
  "disabled_providers": ["opencode"],
  "share": "disabled",
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "Qwen/Qwen3-8B-GGUF:Q8_0": {}
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.5:9b": { "name": "Qwen 3.5" },
        "ministral-3:8b": { "name": "Ministral 3" },
      }
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "echo *": "allow",
      "find *": "allow",
      "find *exec*": "ask",
      "git branch *": "allow",
      "git branch *-d*": "ask",
      "git branch *-D*": "ask",
      "git diff *": "allow",
      "git log *": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head": "allow",
      "head *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "make build": "allow",
      "make test": "allow",
      "rg *" : "allow",
      "sort *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
    },
    "edit": "ask",
    "external_directory": "ask",
    "webfetch": "ask"
  },
  "formatter": {
    "csharpier": {
      "command": ["csharpier", "format", "$FILE"],
      "extensions": [".cs"]
    }
  },
  "watcher": {
    "ignore": [".git/**"]
  }
}
